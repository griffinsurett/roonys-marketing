---
import BenefitCardMotion from '../components/BenefitCardMotion.jsx';
import TikTokProfileIsland from '../components/examples/islands/TikTokProfileIsland.jsx';
import TikTokFollowersIsland from '../components/examples/islands/TikTokFollowersIsland.jsx';
import PayingCustomersIsland from '../components/examples/islands/PayingCustomersIsland.jsx';
import CreatorMonetizeIsland from '../components/examples/islands/CreatorMonetizeIsland.jsx';
import AgencyWhiteLabelIsland from '../components/examples/islands/AgencyWhiteLabelIsland.jsx';
import AudienceQualityIsland from '../components/examples/islands/AudienceQualityIsland.jsx';
import OnePlatformIsland from '../components/examples/islands/OnePlatformIsland.jsx';
import AutoDMIsland from '../components/examples/islands/AutoDMIsland.jsx';

const benefits = [
  {
    heading: 'PROVEN VIRALITY.\nNOT LUCK.',
    body: "Viral content isn't a happy accident — it's engineered. We study what the algorithm rewards: watch-through rate, saves, shares, replays. Then we build every video around those exact signals so your content gets pushed, not buried.",
  },
  {
    heading: 'VIEWERS INTO\nLOYAL FOLLOWERS.',
    body: "A view means nothing if they don't come back. We craft content with identity, personality, and a consistent voice that makes people hit follow because they don't want to miss what's next.",
  },
  {
    heading: 'FOLLOWERS INTO\nPAYING CUSTOMERS.',
    body: 'For businesses, attention is only the first step. Every script, CTA, and edit is built to move warm viewers down the funnel — from watching to clicking to buying.',
  },
  {
    heading: 'CREATORS BUILT\nTO MONETIZE.',
    body: 'Brand deals, platform payouts, digital products — they all require one thing: a loyal audience that watches till the end. We build the content strategy that gets you there.',
  },
  {
    heading: 'AGENCIES THAT\nNEED TO DELIVER.',
    body: 'White-label, NDA-friendly, and built to slot into your workflow invisibly. Your client gets scroll-stopping short-form content. You get the credit. We handle everything behind the scenes.',
  },
  {
    heading: 'THE RIGHT\nAUDIENCE.\nNOT JUST A\nBIG ONE.',
    body: '10,000 followers who actually care beat 100,000 who scroll past. We build content that speaks directly to your niche — the right hooks, the right language, the right people — so every new follower is a potential customer, not just a number.',
  },
  {
    heading: 'ONE SHOOT.\nEVERY PLATFORM.',
    body: "TikTok, Instagram Reels, YouTube Shorts — three algorithms, three audiences, three sets of rules. We repurpose, resize, and re-caption every piece of content so you dominate all three without doing triple the work.",
  },
  {
    heading: 'CONTENT THAT\nWORKS WHILE\nYOU SLEEP.',
    body: 'Every comment is a lead. We build automation into your content strategy — viewers drop a trigger word, and your DMs fire back instantly with the link, the offer, or the booking. No manual follow-up. No missed opportunities.',
  },
];

const islands = [
  TikTokProfileIsland,
  TikTokFollowersIsland,
  PayingCustomersIsland,
  CreatorMonetizeIsland,
  AgencyWhiteLabelIsland,
  AudienceQualityIsland,
  OnePlatformIsland,
  AutoDMIsland,
];
---

<section id="benefits" class="relative py-24 lg:py-32">
  <div class="section-container relative z-10 flex flex-col gap-60">

    <!-- Card 0: Proven Virality -->
    <BenefitCardMotion client:visible>
      <div class="flex flex-col lg:flex-row items-stretch">
        <div class="w-full lg:w-2/3 flex items-center justify-center p-6 lg:p-8">
          <div class="w-full aspect-4/3 rounded-[3rem] flex items-center justify-center" style="background: rgba(0,0,0,0.25)">
            <TikTokProfileIsland client:visible />
          </div>
        </div>
        <div class="w-full lg:w-1/3 flex flex-col justify-center p-8 lg:p-14 gap-6">
          <h3 class="text-2xl lg:text-3xl xl:text-4xl font-black text-white uppercase leading-tight tracking-tight whitespace-pre-line">{benefits[0].heading}</h3>
          <p class="text-white/90 text-lg lg:text-xl leading-relaxed font-medium">{benefits[0].body}</p>
        </div>
      </div>
    </BenefitCardMotion>

    <!-- Card 1: Viewers into Followers -->
    <BenefitCardMotion client:visible>
      <div class="flex flex-col lg:flex-row-reverse items-stretch">
        <div class="w-full lg:w-2/3 flex items-center justify-center p-6 lg:p-8">
          <div class="w-full aspect-4/3 rounded-[3rem] flex items-center justify-center" style="background: rgba(0,0,0,0.25)">
            <TikTokFollowersIsland client:visible />
          </div>
        </div>
        <div class="w-full lg:w-1/3 flex flex-col justify-center p-8 lg:p-14 gap-6">
          <h3 class="text-2xl lg:text-3xl xl:text-4xl font-black text-white uppercase leading-tight tracking-tight whitespace-pre-line">{benefits[1].heading}</h3>
          <p class="text-white/90 text-lg lg:text-xl leading-relaxed font-medium">{benefits[1].body}</p>
        </div>
      </div>
    </BenefitCardMotion>

    <!-- Card 2: Followers into Paying Customers -->
    <BenefitCardMotion client:visible>
      <div class="flex flex-col lg:flex-row items-stretch">
        <div class="w-full lg:w-2/3 flex items-center justify-center p-6 lg:p-8">
          <div class="w-full aspect-4/3 rounded-[3rem] flex items-center justify-center" style="background: rgba(0,0,0,0.25)">
            <PayingCustomersIsland client:visible />
          </div>
        </div>
        <div class="w-full lg:w-1/3 flex flex-col justify-center p-8 lg:p-14 gap-6">
          <h3 class="text-2xl lg:text-3xl xl:text-4xl font-black text-white uppercase leading-tight tracking-tight whitespace-pre-line">{benefits[2].heading}</h3>
          <p class="text-white/90 text-lg lg:text-xl leading-relaxed font-medium">{benefits[2].body}</p>
        </div>
      </div>
    </BenefitCardMotion>

    <!-- Card 3: Creators Built to Monetize -->
    <BenefitCardMotion client:visible>
      <div class="flex flex-col lg:flex-row-reverse items-stretch">
        <div class="w-full lg:w-2/3 flex items-center justify-center p-6 lg:p-8">
          <div class="w-full aspect-4/3 rounded-[3rem] flex items-center justify-center" style="background: rgba(0,0,0,0.25)">
            <CreatorMonetizeIsland client:visible />
          </div>
        </div>
        <div class="w-full lg:w-1/3 flex flex-col justify-center p-8 lg:p-14 gap-6">
          <h3 class="text-2xl lg:text-3xl xl:text-4xl font-black text-white uppercase leading-tight tracking-tight whitespace-pre-line">{benefits[3].heading}</h3>
          <p class="text-white/90 text-lg lg:text-xl leading-relaxed font-medium">{benefits[3].body}</p>
        </div>
      </div>
    </BenefitCardMotion>

    <!-- Card 4: Agencies -->
    <BenefitCardMotion client:visible>
      <div class="flex flex-col lg:flex-row items-stretch">
        <div class="w-full lg:w-2/3 flex items-center justify-center p-6 lg:p-8">
          <div class="w-full aspect-4/3 rounded-[3rem] flex items-center justify-center" style="background: rgba(0,0,0,0.25)">
            <AgencyWhiteLabelIsland client:visible />
          </div>
        </div>
        <div class="w-full lg:w-1/3 flex flex-col justify-center p-8 lg:p-14 gap-6">
          <h3 class="text-2xl lg:text-3xl xl:text-4xl font-black text-white uppercase leading-tight tracking-tight whitespace-pre-line">{benefits[4].heading}</h3>
          <p class="text-white/90 text-lg lg:text-xl leading-relaxed font-medium">{benefits[4].body}</p>
        </div>
      </div>
    </BenefitCardMotion>

    <!-- Card 5: The Right Audience -->
    <BenefitCardMotion client:visible>
      <div class="flex flex-col lg:flex-row-reverse items-stretch">
        <div class="w-full lg:w-2/3 flex items-center justify-center p-6 lg:p-8">
          <div class="w-full aspect-4/3 rounded-[3rem] flex items-center justify-center" style="background: rgba(0,0,0,0.25)">
            <AudienceQualityIsland client:visible />
          </div>
        </div>
        <div class="w-full lg:w-1/3 flex flex-col justify-center p-8 lg:p-14 gap-6">
          <h3 class="text-2xl lg:text-3xl xl:text-4xl font-black text-white uppercase leading-tight tracking-tight whitespace-pre-line">{benefits[5].heading}</h3>
          <p class="text-white/90 text-lg lg:text-xl leading-relaxed font-medium">{benefits[5].body}</p>
        </div>
      </div>
    </BenefitCardMotion>

    <!-- Card 6: One Shoot Every Platform -->
    <BenefitCardMotion client:visible>
      <div class="flex flex-col lg:flex-row items-stretch">
        <div class="w-full lg:w-2/3 flex items-center justify-center p-6 lg:p-8">
          <div class="w-full aspect-4/3 rounded-[3rem] flex items-center justify-center" style="background: rgba(0,0,0,0.25)">
            <OnePlatformIsland client:visible />
          </div>
        </div>
        <div class="w-full lg:w-1/3 flex flex-col justify-center p-8 lg:p-14 gap-6">
          <h3 class="text-2xl lg:text-3xl xl:text-4xl font-black text-white uppercase leading-tight tracking-tight whitespace-pre-line">{benefits[6].heading}</h3>
          <p class="text-white/90 text-lg lg:text-xl leading-relaxed font-medium">{benefits[6].body}</p>
        </div>
      </div>
    </BenefitCardMotion>

    <!-- Card 7: Content That Works While You Sleep -->
    <BenefitCardMotion client:visible>
      <div class="flex flex-col lg:flex-row-reverse items-stretch">
        <div class="w-full lg:w-2/3 flex items-center justify-center p-6 lg:p-8">
          <div class="w-full aspect-4/3 rounded-[3rem] flex items-center justify-center" style="background: rgba(0,0,0,0.25)">
            <AutoDMIsland client:visible />
          </div>
        </div>
        <div class="w-full lg:w-1/3 flex flex-col justify-center p-8 lg:p-14 gap-6">
          <h3 class="text-2xl lg:text-3xl xl:text-4xl font-black text-white uppercase leading-tight tracking-tight whitespace-pre-line">{benefits[7].heading}</h3>
          <p class="text-white/90 text-lg lg:text-xl leading-relaxed font-medium">{benefits[7].body}</p>
        </div>
      </div>
    </BenefitCardMotion>

  </div>
</section>
